FRONTEND_URL=http://127.0.0.1:5173
BACKEND_PUBLIC_URL=http://127.0.0.1:8000

# Ollama agent model (must support tool calling: qwen3, qwen2.5, llama3.1...)
OLLAMA_MODEL=qwen3:8b
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_TIMEOUT_SECONDS=300

# JWT settings
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# Password reset emails using Resend.
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=Study Assistant <onboarding@resend.dev>

# OAuth provider apps must use this callback URL:
# Google: http://127.0.0.1:8000/oauth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
